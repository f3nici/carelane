PORT=3778
NODE_ENV=development
DEFAULT_USERNAME=admin
# Seeds the first admin login. Required in production: the app refuses to start
# if this is unset or left at 'changeme'. Set a strong value before first run
# (or rotate the password in-app afterwards and set this to that value).
DEFAULT_PASSWORD=changeme
SESSION_SECRET=change-me
# Required in production; the app refuses to start if unset or left at default.
# WARNING: cannot be rotated casually — once data is encrypted with this secret,
# changing it makes existing PII unreadable. Back it up securely.
ENCRYPTION_SECRET=change-me

# CLAUDE Ai draft writing (optional)
ANTHROPIC_API_KEY=

# Google Calendar one-way sync (optional). Create an OAuth 2.0 "Web application"
# client in Google Cloud Console, enable the Google Calendar API, and add the
# redirect URI below to its authorised redirect URIs. Leave blank to disable —
# scheduling works fully without it. The per-account refresh token is stored
# encrypted in the database (never here). Connect the account from Settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3778/api/v1/schedule/google/callback

# Square invoicing (optional). Create an application in the Square Developer
# Dashboard and copy its access token here. The token is a secret read only from
# the environment — it is never stored in the database. SQUARE_ENVIRONMENT must
# match the token (a sandbox token needs 'sandbox'). The location is auto-detected
# and saved on the first "Test connection" in Settings — no env var needed. Leave
# blank to disable. See docs/square-invoicing-setup.md.
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# ntfy push notifications (optional). nothing here is required to start using it on the
# public ntfy.sh.
# NTFY_TOKEN: only needed for an access-protected or self-hosted ntfy server
#   (a Bearer token). Like other secrets it is read from env, never stored in DB.
# NTFY_TOKEN=
# Public URL of this install, used to deep-link notifications back to the app.
# APP_BASE_URL=https://carelane.example.org

# Passkeys / WebAuthn (passwordless login). Leave both blank for a same-origin
# deployment — the relying-party id and expected origin are then auto-derived
# from the request. Pin them only when the app runs behind a proxy that rewrites
# the Host header: RP id is the registrable domain (e.g. carelane.example.com),
# origin is its full URL (e.g. https://carelane.example.com).
# WEBAUTHN_RP_ID=
# WEBAUTHN_ORIGIN=

# Public demo mode (optional). When true, CareLane boots as a throwaway public
# showcase: two shared logins are created — a 'demo' admin and a 'demoworker'
# support worker, both with password 'demo' — along with a rich set of fabricated
# example data that is WIPED AND RESEEDED on a fixed cadence (and once at boot).
# Account-security and user-management writes (password / 2FA / passkey changes,
# creating or deactivating logins) are blocked so a visitor cannot lock others
# out. NEVER enable this on an install holding real participant data — a reset
# hard-deletes everything. For the cleanest demo, also set DEFAULT_USERNAME=demo
# and DEFAULT_PASSWORD=demo so no separate admin/changeme login is seeded.
DEMO_MODE=false
# How often (hours) the demo data resets. Default 6. Ignored unless DEMO_MODE=true.
DEMO_RESET_HOURS=6

# LOG_LEVEL: debug|info|warn|error.
LOG_LEVEL=warn
# LOG_FORMAT: json|pretty
LOG_FORMAT=pretty

# Prometheus metrics at /metrics for self-hosters running monitoring. Disabled by
# default. When enabled it is open (intended for an internal-only scrape target,
# like /healthz) unless METRICS_TOKEN is set, which then requires it as a Bearer
# token (or ?token=).
METRICS_ENABLED=false
# METRICS_TOKEN=

# Should be fine to leave all of the below as defaults

DB_PATH=./data/carelane.db
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5
# Leave unset to auto-apply the bge query instruction; set empty for other models.
# EMBEDDING_QUERY_PREFIX=
# Hybrid search: candidates pulled from each of the vector + keyword (BM25) arms.
SEARCH_CANDIDATE_POOL=40
# Local cross-encoder reranker (big precision gain; degrades gracefully offline).
RERANK_ENABLED=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
DEFAULT_PRICE_REGION=standard
BACKUP_ENABLED=true
BACKUP_PATH=./data/backups
BACKUP_RETENTION=14
BACKUP_TIME=02:00
# Warn loudly on startup if the newest backup is older than this many hours.
BACKUP_STALE_HOURS=48
# Login brute-force protection: lock an ip+username after this many failed
# attempts within the window (minutes). The throttle (and the per-route rate
# limiters) are DB-backed, so lockouts survive restarts and hold across workers.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
PUBLIC_API_ENABLED=false
CORS_ORIGINS=http://localhost:5173
