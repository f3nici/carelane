PORT=3778
NODE_ENV=development
SESSION_SECRET=change-me
# Required in production; the app refuses to start if unset or left at default.
# WARNING: cannot be rotated casually — once data is encrypted with this secret,
# changing it makes existing PII unreadable. Back it up securely.
ENCRYPTION_SECRET=change-me
ANTHROPIC_API_KEY=
CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001
CLAUDE_MODEL_QUALITY=claude-sonnet-4-6
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=changeme
DB_PATH=./data/carelane.db
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
DEFAULT_PRICE_REGION=standard
BACKUP_ENABLED=true
BACKUP_PATH=./data/backups
BACKUP_RETENTION=14
BACKUP_TIME=02:00
# Warn loudly on startup if the newest backup is older than this many hours.
BACKUP_STALE_HOURS=48
# Login brute-force protection: lock an ip+username after this many failed
# attempts within the window (minutes).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
PUBLIC_API_ENABLED=false
CORS_ORIGINS=http://localhost:5173
