{
  "name": "carelane",
  "version": "0.8.0",
  "description": "NDIS independent support worker management system",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "migrate": "node server/db/migrate.js",
    "seed": "node server/db/seed.js",
    "reindex": "node server/scripts/reindex.js",
    "restore": "node server/db/restore.js",
    "reset-password": "node server/db/resetPassword.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:core": "npm run build --workspace=@carelane/core",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f3nici/carelane.git"
  },
  "bugs": {
    "url": "https://github.com/f3nici/carelane/issues"
  },
  "homepage": "https://github.com/f3nici/carelane#readme",
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@carelane/core": "*",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^8.0.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "better-sqlite3-session-store": "^0.1.0",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.2",
    "sqlite-vec": "^0.1.9",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "vue": "^3.5.38",
    "vue-cal": "^4.10.2",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
