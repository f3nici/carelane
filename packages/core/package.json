{
  "name": "@carelane/core",
  "version": "0.8.0",
  "description": "CareLane portable domain logic — runs unmodified in Node (server) and React Native (app)",
  "type": "module",
  "main": "./src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
